# Configurações da aplicação YOUVISA - Sprint 4
APP_NAME=YOUVISA
APP_ENV=development
DATABASE_URL=sqlite:///./youvisa.db

# Modo de operação dos agentes: "mock" usa respostas simuladas (sem API externa)
# Para integrar com Claude/OpenAI no futuro, troque para "claude" ou "openai"
LLM_MODE=mock

# Chave opcional (não necessária no modo mock)
LLM_API_KEY=

# Governança - escopo permitido para o assistente
ALLOWED_SCOPE=visto,passaporte,documentos,processo,status
